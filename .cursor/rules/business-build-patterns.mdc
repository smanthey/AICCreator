## API Endpoint Template

```javascript
// Add to scripts/business-api.js

async function handleBusinessOverview(req, res) {
  const { rows: revenue } = await pg.query(
    `SELECT 
       source_platform,
       SUM(amount_usd)::numeric(10,2) AS total_revenue,
       COUNT(*)::int AS transaction_count
     FROM business_revenue
     WHERE transaction_date >= $1
     GROUP BY source_platform`,
    [req.query.start_date || 'NOW() - INTERVAL \'30 days\'']
  );
  
  return jsonResponse(res, 200, { revenue });
}
```

