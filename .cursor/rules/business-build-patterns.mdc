# Business Build Patterns

Templates and patterns for building business intelligence system components.

## Sync Script Template

```javascript
#!/usr/bin/env node
"use strict";

/**
 * business-{platform}-sync.js — {Platform} Data Collector
 * 
 * Syncs {data types} from {Platform} API to unified business schema.
 */

require("dotenv").config({ override: true });

const pg = require("../infra/postgres");

const PLATFORM = "{platform}";

// ─── Authentication ────────────────────────────────────────────────────────

async function authenticate() {
  // Implement authentication based on platform
  // OAuth, API key, etc.
}

// ─── Sync Functions ────────────────────────────────────────────────────────

async function syncOrders(lastSyncAt = null) {
  // Fetch orders from platform API
  // Transform to unified schema
  // Store in business_orders table
  // Log to business_sync_logs
}

async function syncProducts() {
  // Fetch products from platform API
  // Transform to unified schema
  // Store in business_products table
}

async function syncCustomers() {
  // Fetch customers from platform API
  // Match across platforms
  // Store in business_customers table
}

// ─── Main Sync Function ─────────────────────────────────────────────────────

async function main() {
  const syncLogId = await startSyncLog(PLATFORM, "incremental");
  
  try {
    await authenticate();
    await syncOrders();
    await syncProducts();
    await syncCustomers();
    
    await completeSyncLog(syncLogId, "completed", recordsSynced);
  } catch (err) {
    await failSyncLog(syncLogId, err);
    throw err;
  }
}

if (require.main === module) {
  main().catch(console.error);
}

module.exports = { main, syncOrders, syncProducts, syncCustomers };
```

