# Domain that will serve all dashboard routes:
#   /
#   /local-alternatives
#   /offgrid-home
#   /masterpiece
#   /workshop-openclaw
#   /openclaw-creator-studio
#   /api/*
DASHBOARD_DOMAIN=dashboard.yourdomain.com
DASHBOARD_EMAIL=you@yourdomain.com

# Basic auth credentials for internet-facing access.
# Generate hash:
#   docker run --rm caddy:2.9-alpine caddy hash-password --plaintext 'CHANGE_ME'
DASHBOARD_BASICAUTH_USER=ops
DASHBOARD_BASICAUTH_HASH=$2a$14$REPLACE_ME

# Optional Cloudflare Tunnel token (for no-port-forward internet access).
# If set, run compose with --profile tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# New public dashboard URL for the Masterpiece lane (path under DASHBOARD_DOMAIN).
# Example:
#   https://dashboard.yourdomain.com/masterpiece
MASTERPIECE_PUBLIC_PATH=/masterpiece

# CORS allowlist for browser API calls from hosted + local dashboards.
ARCHITECT_ALLOWED_ORIGINS=https://dashboard.yourdomain.com,http://127.0.0.1:4051,http://localhost:4051

# Existing API key protection still applies for /api/*
ARCHITECT_API_KEY=CHANGE_ME_STRONG_KEY
