  },
  "document_classification": {
    "threshold": 4,
    "types": {
      "office_action": {
        "weights": {
          "office action": 5,
          "examining attorney": 3,
          "response required": 2,
          "trademark act section": 2
        }
      },
      "filing_receipt": {
        "weights": {
          "filing receipt": 5,
          "serial number": 3,
          "received date": 2,
          "successfully submitted": 2
        }
      },
      "notice_of_allowance": {
        "weights": {
          "notice of allowance": 5,
          "statement of use": 2,
          "extension request": 2
        }
      },
      "registration_certificate": {
        "weights": {
          "certificate of registration": 5,
          "registered on": 2
        }
      },
      "teas_filing": {
        "weights": {
          "teas": 4,
          "teasi": 4,
          "trademark electronic application system": 3
        }
      }
    }
  },
  "issue_detection": {
