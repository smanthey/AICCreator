{
  "mcpServers": {
    "trigger": {
      "command": "npx",
      "args": [
        "trigger.dev@4.4.1",
        "mcp"
      ],
      "x_policy": {
        "strategy": "resources_first_tools_second",
        "use_when": "Use trigger when authoritative trigger context is needed.",
        "do_not_use_when": "Do not use trigger when another source is already sufficient.",
        "require_confirmation_on_write": true,
        "tools": []
      },
      "x_remote_oauth": {
        "enabled": true,
        "transport": [
          "http",
          "sse"
        ],
        "oauth": {
          "required": true,
          "default_scope_strategy": "least_privilege",
          "token_ttl_minutes": 60,
          "refresh_required": true
        },
        "writes": {
          "no_broad_write_by_default": true,
          "explicit_confirmation_required": true,
          "allowlisted_tools_only": true
        },
        "connector_rollout": {
          "chatgpt_codex_remote_only": true,
          "streaming_enabled": true
        }
      }
    },
    "jcodemunch": {
      "command": "./scripts/jcodemunch-mcp.sh",
      "x_policy": {
        "strategy": "resources_first_tools_second",
        "use_when": "Use jcodemunch when authoritative jcodemunch context is needed.",
        "do_not_use_when": "Do not use jcodemunch when another source is already sufficient.",
        "require_confirmation_on_write": true,
        "tools": []
      },
      "x_remote_oauth": {
        "enabled": true,
        "transport": [
          "http",
          "sse"
        ],
        "oauth": {
          "required": true,
          "default_scope_strategy": "least_privilege",
          "token_ttl_minutes": 60,
          "refresh_required": true
        },
        "writes": {
          "no_broad_write_by_default": true,
          "explicit_confirmation_required": true,
          "allowlisted_tools_only": true
        },
        "connector_rollout": {
          "chatgpt_codex_remote_only": true,
          "streaming_enabled": true
        }
      }
    },
    "postgres": {
      "command": "./scripts/mcp-postgres.sh",
      "x_policy": {
        "strategy": "resources_first_tools_second",
        "use_when": "Use postgres when authoritative postgres context is needed.",
        "do_not_use_when": "Do not use postgres when another source is already sufficient.",
        "require_confirmation_on_write": true,
        "tools": [
          {
            "id": "postgres.query",
            "class": "read",
            "use_when": "You need database-backed facts, counts, or retrieval results.",
            "do_not_use_when": "A cached answer is fresh and sufficient."
          },
          {
            "id": "postgres.write",
            "class": "write",
            "use_when": "A bounded data mutation is required for a validated workflow.",
            "do_not_use_when": "Schema intent is unclear or rollback path is unknown.",
            "requires_confirmation": true
          }
        ]
      },
      "x_remote_oauth": {
        "enabled": true,
        "transport": [
          "http",
          "sse"
        ],
        "oauth": {
          "required": true,
          "default_scope_strategy": "least_privilege",
          "token_ttl_minutes": 60,
          "refresh_required": true
        },
        "writes": {
          "no_broad_write_by_default": true,
          "explicit_confirmation_required": true,
          "allowlisted_tools_only": true
        },
        "connector_rollout": {
          "chatgpt_codex_remote_only": true,
          "streaming_enabled": true
        }
      }
    },
    "filesystem": {
      "command": "./scripts/mcp-filesystem.sh",
      "x_policy": {
        "strategy": "resources_first_tools_second",
        "use_when": "You need local file/directory content or metadata from workspace paths.",
        "do_not_use_when": "You need web data, credentials, or to mutate files.",
        "require_confirmation_on_write": true,
        "tools": [
          {
            "id": "filesystem.read",
            "class": "read",
            "use_when": "You need local file/directory content or metadata from workspace paths.",
            "do_not_use_when": "You need web data, credentials, or to mutate files."
          },
          {
            "id": "filesystem.write",
            "class": "write",
            "use_when": "A concrete file change is approved and path scope is known.",
            "do_not_use_when": "The edit is speculative, broad, or reversible planning only.",
            "requires_confirmation": true
          }
        ]
      },
      "x_remote_oauth": {
        "enabled": true,
        "transport": [
          "http",
          "sse"
        ],
        "oauth": {
          "required": true,
          "default_scope_strategy": "least_privilege",
          "token_ttl_minutes": 60,
          "refresh_required": true
        },
        "writes": {
          "no_broad_write_by_default": true,
          "explicit_confirmation_required": true,
          "allowlisted_tools_only": true
        },
        "connector_rollout": {
          "chatgpt_codex_remote_only": true,
          "streaming_enabled": true
        }
      }
    },
    "github": {
      "command": "./scripts/mcp-github.sh",
      "x_policy": {
        "strategy": "resources_first_tools_second",
        "use_when": "Use github when authoritative github context is needed.",
        "do_not_use_when": "Do not use github when another source is already sufficient.",
        "require_confirmation_on_write": true,
        "tools": [
          {
            "id": "github.search",
            "class": "read",
            "use_when": "You need repository/issue/code discovery from GitHub.",
            "do_not_use_when": "You already have the content locally or only need a single known file."
          }
        ]
      },
      "x_remote_oauth": {
