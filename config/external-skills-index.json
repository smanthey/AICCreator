    },
    {
      "repo_id": "local/superpowers",
      "path_tail": "superpowers",
      "use_for": ["systematic_debugging", "render_graphs", "SWE_lifecycle"],
      "best_symbols": ["render-graphs", "condition-based-waiting", "skills-core"]
    },
    {
      "repo_id": "local/planning-with-files",
      "path_tail": "planning-with-files",
      "use_for": ["session_catchup", "persistent_planning", "multi_day_refactors"],
      "best_symbols": ["session-catchup", "session_catchup"]
    },
    {
      "repo_id": "local/skill-prompt-generator",
      "path_tail": "skill-prompt-generator",
      "use_for": ["skill_design", "prompt_audit", "prompt_extractor", "prompt_xray"],
