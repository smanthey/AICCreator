# ─────────────────────────────────────────────────────────────
# Claw Architect — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Redis (BullMQ queue backbone) ────────────────────────────
REDIS_HOST=192.168.1.164
REDIS_PORT=16379
# Event bus: domain events stream (mediated swarm). Set false to disable all publish.
EVENTS_PUBLISH_DOMAIN_TO_REDIS=true
EVENTS_STREAM_DOMAIN=events.domain
# Loyalty: publish loyalty.points.earned etc. to events.domain when true
LOYALTY_PUBLISH_EVENTS_TO_REDIS=false
# Events consumer: write consumed events to event_bus_audit table (scripts/events-domain-consumer.js). C8: set true for audit.
EVENTS_AUDIT_TO_PG=true
# Event spawner rate limit: one task per (event_type, entity_id) per N minutes
EVENT_SPAWN_DEBOUNCE_MINUTES=5
# Health: report events_domain pending as warn when above this
EVENTS_LAG_WARN=1000

# ── Postgres — Architect DB (NAS) ───────────────────────────
POSTGRES_HOST=192.168.1.164
POSTGRES_PORT=15432
POSTGRES_USER=claw
POSTGRES_PASSWORD=
POSTGRES_DB=claw_architect

# ── Postgres — Claw Indexer DB (data plane) ─────────────────
# Defaults to POSTGRES_HOST/USER/PASSWORD if not set.
# Only override if the claw DB is on a different host/port.
CLAW_DB_HOST=192.168.1.164
CLAW_DB_PORT=15432
CLAW_DB_USER=claw
CLAW_DB_PASSWORD=
CLAW_DB_NAME=claw

# ── Anthropic API ────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_ALLOWED=true

# ── DeepSeek API (OpenAI-compatible) ─────────────────────────
DEEPSEEK_API_KEY=
# Optional alias:
# DEEPSEEK_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_FAST=deepseek-chat
DEEPSEEK_MODEL_REASONER=deepseek-reasoner

# ── Gemini API (Google AI Studio / Google account) ───────────
GEMINI_API_KEY=
# Optional aliases:
# GOOGLE_API_KEY=
# GOOGLE_GENAI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# ── OpenAI API (Codex + mini acceleration lane) ─────────────
OPENAI_API_KEY=
# OpenAI-compatible endpoint (OpenAI / LM Studio / Jan / vLLM / Ollama gateway)
OPENAI_BASE_URL=https://api.openai.com/v1
# Fast low-cost model used for heavy throughput tasks
OPENAI_MODEL_FAST=gpt-4o-mini
# High-reasoning model reserved for coding/audit lanes
OPENAI_MODEL_CODEX=gpt-4o
# Qwen copy/research lane (OpenAI-compatible)
OPENAI_MODEL_QWEN35=qwen3.5-72b-instruct

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_ENABLE_MESSAGE_CONTENT_INTENT=false
DISCORD_OPTIONAL=true

# ── Moltbook / Forum Harvesting ─────────────────────────────
# Moltbook API key (if available)
MOLTBOOK_API_KEY=
MOLTBOOK_API_BASE=https://api.moltbook.com
# Harvest sources: moltbook,reddit
MOLTBOOK_HARVEST_SOURCES=moltbook,reddit
MOLTBOOK_HARVEST_MAX_POSTS=120
MOLTBOOK_MIN_INTENT_SCORE=70
MOLTBOOK_AUTO_REPLY=false
MOLTBOOK_MAX_REPLIES=15
MOLTBOOK_REDDIT_SUBREDDITS=Moltbook,AI_Agents,LocalLLaMA,LLMDevs,openclaw

# ── Worker config — set per machine ─────────────────────────
# Canonical tags: infra, deterministic, ai, qa, cpu_heavy, io_heavy
# Legacy tags still work: io_light, llm_local, llm_remote
# Comma-separated for machines that handle multiple roles.
# NAS example: WORKER_TAGS=infra,deterministic,io_heavy,cpu_heavy
# M3 AI example: WORKER_TAGS=ai,qa
WORKER_TAGS=infra,deterministic,io_heavy
NODE_ROLE=worker
# Per-queue concurrency (defaults: ai/io_heavy/cpu_heavy=1, others=2). Increase for parallel tasks.
# WORKER_CONCURRENCY_AI=2
# WORKER_CONCURRENCY_IO_HEAVY=2
# Long-running tasks: increase lock so jobs are not marked stalled (default 30000 ms).
# WORKER_LOCK_DURATION_MS=120000
# WORKER_STALLED_INTERVAL_MS=60000
# Enforce role/tag policy at startup:
# nas_worker must include infra,deterministic,io_heavy and cannot include ai tags.
# ai_worker must include ai and cannot include infra/deterministic.
WORKER_ENFORCE_ROLE_TAG_POLICY=true

# ── Ollama (for llm_local workers with M3/M4) ────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_FAST=llama3.1:8b
OLLAMA_CLASSIFY_MODEL=llama3.1:8b
# Optional multi-host fanout (comma-separated): http://m3max:11434,http://m1worker:11434
# OLLAMA_HOSTS=http://127.0.0.1:11434
# Optional fleet host alias (used by model-fleet setup tooling)
# MODEL_FLEET_OLLAMA_HOSTS=http://127.0.0.1:11434,http://192.168.1.50:11434,http://192.168.1.51:11434
# Optional: prefer non-local Ollama hosts first when router picks host
# OLLAMA_REMOTE_FIRST=false
# Optional remote pull map for fleet setup:
# MODEL_FLEET_SSH_MAP=http://192.168.1.50:11434=user@m1a,http://192.168.1.51:11434=user@m1b
# Portfolio models (set to tags available on each machine)
OLLAMA_MODEL_QWEN3_32B=qwen2.5:14b
OLLAMA_MODEL_QWEN3_14B=qwen2.5:14b
OLLAMA_MODEL_QWEN3_7B=llama3.1:8b
OLLAMA_MODEL_QWEN3_4B=llama3.1:8b
OLLAMA_MODEL_QWEN3_1_7B=llama3.1:8b
OLLAMA_MODEL_QWEN3_CODER_30B=qwen2.5-coder:7b
OLLAMA_MODEL_CODESTRAL_22B=deepseek-coder:6.7b
OLLAMA_MODEL_MISTRAL_SMALL_3_2=llama3.1:8b
OLLAMA_MODEL_DEEPSEEK_R1=deepseek-r1:8b
OLLAMA_MODEL_DEEPSEEK_V3=deepseek-r1:8b
OLLAMA_MODEL_LLAMA3_2_3B=llama3.1:8b
OLLAMA_MODEL_GEMMA_2B=llama3.1:8b

# ── Feature Benchmark Merge Gate ───────────────────────────────
FEATURE_BENCHMARK_ENFORCE=true
FEATURE_BENCHMARK_GATE_STRICT=true
FEATURE_BENCHMARK_GATE_MAX_AGE_HOURS=48
FEATURE_BENCHMARK_MIN_DELTA=0.25
FEATURE_BENCHMARK_TOP_N=10

# ── ClawVault — NAS mount path for migrate agent ─────────────
# Must be mounted before migrate tasks run.
# macOS: /Volumes/ClawVault  |  Linux: /mnt/vault
NAS_VAULT_PATH=/Volumes/ClawVault

# ── Patch agent — local repo path for git branch creation ────
# Set on dev machines where patch tasks run.
# Example: /Users/tatsheen/claw-architect
REPO_PATH=

# ── Content Research (fetch_content / analyze_content) ───────
# YouTube Data API v3 — get from Google Cloud Console
YOUTUBE_API_KEY=
# Apify API key — for TikTok and Instagram scraping
# https://console.apify.com/account/integrations
APIFY_API_KEY=

# ── Lead Generation (fetch_leads) ────────────────────────────
# Google Places API key — enable "Places API" in Google Cloud Console
GOOGLE_PLACES_API_KEY=

# ── Lead Gen / Autopilot ────────────────────────────────────
# Brand slug for lead pipeline: skynpatch | plushtrap | blackwallstreetopoly
LEADGEN_BRAND_SLUG=skynpatch
# For Black Wallstreetopoly: toy store|gift shop|boutique|bookstore
# For Skyn Patch: health food store|gym supplement store|vitamin shop
LEAD_AUTOPILOT_QUERIES=health food store|gym supplement store|vitamin shop|wellness store
# Cities for autopilot scrape (pipe-separated)
# SkynPatch default (national): Los Angeles, CA|Dallas, TX|Miami, FL|Chicago, IL|New York, NY|Atlanta, GA
# BWS default: Atlanta, GA|Houston, TX|Washington, DC|Nashville, TN
LEAD_AUTOPILOT_CITIES=Los Angeles, CA|Dallas, TX|Miami, FL|Chicago, IL|New York, NY|Atlanta, GA
# Set true to collect/scrape/enrich leads but skip all email sends.
LEAD_AUTOPILOT_DISABLE_SEND=false

# ── Outbound Email — Brevo for Skyn Patch + BWS (3dgameartacademy.com) ─────
# BWS uses 3D Game Art Academy (3dgameartacademy.com + Brevo), not Skyn Patch. Verify both domains in Brevo.
EMAIL_PROVIDER=brevo
# Brevo API key (app.brevo.com → SMTP & API → API Keys). One key can send from multiple verified domains.
BREVO_API_KEY=
# Optional: webhook signing secret if you add Brevo webhook (bounces, opens) to email-hub or site.
# BREVO_WEBHOOK_SECRET=

# Skyn Patch sender (domain: skynpatch.com — verify in Brevo)
MAILEROO_FROM_EMAIL=shop@skynpatch.com
MAILEROO_FROM_NAME=Scott

# BWS sender — domain is 3dgameartacademy.com (verify in Brevo)
BLACKWALLSTREETOPOLY_FROM_EMAIL=hello@3dgameartacademy.com
BLACKWALLSTREETOPOLY_FROM_NAME=3D Game Art Academy
# Allowed from addresses (must include both Skyn Patch and BWS senders for outbound-email-policy)
MAILEROO_ALLOWED_FROM_EMAILS=shop@skynpatch.com,hello@3dgameartacademy.com

# Fallback: Maileroo/Resend if you set keys (optional)
# MAILEROO_API_KEY=
# RESEND_API_KEY=re_xxxxxxxx

# BWS wholesale: product/game box image URL (publicly accessible)
# BWS_PRODUCT_IMAGE_URL=https://example.com/bws-game-box.jpg
# SkynPatch lead gen: "Order bundle" link (default https://skynpatch.com/wholesale)
# SKYNPATCH_WHOLESALE_PAGE_URL=https://skynpatch.com/wholesale

# ── 3D Game Art Academy (Replit / Vercel) — copy to that project's secrets ──
# For the 3DGameArtAcademy git repo deployed on Replit and Vercel: add these to Replit Secrets and Vercel Environment Variables.
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-xxxxxxxx
# BREVO_WEBHOOK_SECRET=        # if using Brevo webhooks on that site
# MCP API key (Replit + Vercel secrets) — use either name:
# MCP_API_KEY=
# BREVO_MCP_API_KEY=

# ── GitHub Repo Sync (github_sync) ───────────────────────────
# GitHub Personal Access Token — needed for private repos
# Create at https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=
# GitHub webhook secret for comment-driven agent bridge
# Used by POST /api/webhook/github in scripts/webhook-server.js
GITHUB_WEBHOOK_SECRET=
# Local base directory where client repos are cloned
# Default: ~/claw-repos
REPOS_BASE_PATH=/Users/tatsheen/claw-repos
# GitHub user/org to bootstrap managed repos from
GITHUB_ORG_OR_USER=smanthey

# ── Budget / Cost Controls ────────────────────────────────────
# Maximum total LLM + API spend per calendar day (UTC).
# Plans are rejected if this would be exceeded.
DAILY_COST_CAP_USD=20

# Maximum estimated cost per individual plan.
# Planner is rejected if its estimate exceeds this.
PLAN_COST_CAP_USD=5

# Router-level runtime budget guards (UTC day)
# Skip providers/models when these are reached.
LLM_DAILY_BUDGET_USD=25
OPENAI_DAILY_BUDGET_USD=10
DEEPSEEK_DAILY_BUDGET_USD=8
GEMINI_DAILY_BUDGET_USD=8
OPENAI_CODEX_DAILY_BUDGET_USD=3
ANTHROPIC_DAILY_BUDGET_USD=12
MODEL_BUDGET_REFRESH_MS=30000
MODEL_CONFIDENCE_THRESHOLD=0.72

# Router response cache to cut repeat token spend on retries/duplicates.
MODEL_CACHE_TTL_SEC=900
MODEL_CACHE_TASKS=analyze_content,generate_copy,aicreator,triage,judge

# Router enforcement flags (toggle without code changes)
ROUTER_POLICY_ENFORCE=true
ROUTER_BUDGET_HARD_BLOCK=true
ROUTER_CONFIDENCE_ENFORCE=true
# Prefer non-Anthropic providers globally (DeepSeek/Gemini injected automatically)
MODEL_ROUTING_EXTRA_PROVIDERS=deepseek,gemini
MODEL_ROUTING_ANTHROPIC_LAST=true

# ── Global Red/Green Status Command ───────────────────────────
# Comma-separated URLs that must be reachable for strict global health.
GLOBAL_STATUS_URLS=https://skynpatch.com
GLOBAL_STATUS_REPO_SCAN_MAX_AGE_HOURS=48
GLOBAL_STATUS_CREDIT_ACTIVITY_MAX_AGE_HOURS=24
GLOBAL_STATUS_LEAD_ACTIVITY_MAX_AGE_HOURS=48
GLOBAL_STATUS_URL_TIMEOUT_MS=10000

# Dispatcher: max CREATED tasks claimed per poll (default 10). Increase for many parallel roots.
# DISPATCH_BATCH_LIMIT=20
# Dispatcher AI-lane health gate
AI_LANE_HEALTH_CACHE_MS=30000
AI_LANE_HEALTH_TIMEOUT_MS=4000

# ── Architect API (web dashboard) ───────────────────────────────
ARCHITECT_PORT=4051
# Optional: set to require Bearer token on all /api/* routes
ARCHITECT_API_KEY=

# ── Notifications (iMessage + Telegram) — OFF by default ───────
# Do not send from this machine's iCloud/Telegram to operator devices.
# Leave unset to keep disabled. To enable:
#   IMESSAGE_ENABLED=1
#   IMESSAGE_RECIPIENT=+1... or Apple ID
#   NOTIFY_TELEGRAM_ENABLED=1
#   TELEGRAM_OPERATOR_CHAT_ID=... (get from @userinfobot on Telegram)
# TELEGRAM_OPERATOR_CHAT_ID= was used for dead-letter/budget alerts; now notifier uses iMessage only when enabled.
IMESSAGE_ENABLED=0
# IMESSAGE_RECIPIENT=
# NOTIFY_TELEGRAM_ENABLED=0
TELEGRAM_OPERATOR_CHAT_ID=

# ── Worker memory monitoring ──────────────────────────────────
# Alert in worker log when heap exceeds this (MB). Detects memory leaks.
WORKER_HEAP_WARN_MB=512

# ── Policy engine (local + optional OPA external gate) ───────
# Keep read-only true until mutation workflows are fully vetted.
POLICY_READ_ONLY_MODE=true
POLICY_DISABLE_DESTRUCTIVE_FLAGS=true
POLICY_ALLOWED_PATH_PREFIXES=/Users/tatsheen/claw-architect,/tmp,/Volumes/ClawVault,/volume1,/volume2
POLICY_BLOCKED_TASK_TYPES=

# External OPA gate (recommended on NAS spine)
POLICY_USE_OPA=false
OPA_URL=http://127.0.0.1:8181/v1/data/claw/policy
OPA_TIMEOUT_MS=3000
# If OPA is unavailable, block mutating tasks (migrate, patch, send_email, etc.)
POLICY_OPA_FAIL_CLOSED_MUTATING=true
# AI work pulse (runs model stats + github scan + research signals)
AI_WORK_PULSE_GITHUB_SCAN_LIMIT=40
AI_WORK_PULSE_SIGNALS_LIMIT=120
AI_WORK_PULSE_SIGNALS_DAYS=14

# ── Overnight Self-Maintenance + Backup (4:00 / 4:30) ───────
# Monitoring destination (#monitoring)
# Preferred: Slack webhook to #monitoring
MONITORING_SLACK_WEBHOOK_URL=
# Optional Telegram monitoring fallback (uses TELEGRAM_BOT_TOKEN)
MONITORING_TELEGRAM_CHAT_ID=

# ── Prompt Oracle / Bot Commerce ($1 bot prompt service) ──────────────────────
# Stripe — primary payment rail (automatic_payment_methods mode)
# Account: jamonwidit@plushtrap.com → autopayagent
# Presents all 16 enabled methods automatically: cards, Apple Pay, Google Pay,
# Amazon Pay, CashApp, Crypto/USDC, Klarna, Afterpay, Affirm, Zip, ACH,
# Bank transfer, Bancontact, EPS, Kakao Pay, Samsung Pay
# Keys: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
# Keys: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Your public domain (Stripe needs this for redirect URLs + webhook endpoint)
COMMERCE_PUBLIC_URL=https://openclaw.io
# Price per prompt in USD (default $1.00)
COMMERCE_PRICE_USD=1.00
# Webhook server port for receiving Stripe/Lightning confirmations
COMMERCE_PORT=3031

# Lightning Network via OpenNode (optional — for Bitcoin users)
# Get key at: https://app.opennode.com → API Keys
OPENNODE_API_KEY=

# Private backup repo settings (for sanitized 4:30 backup push)
# Local clone path (default: ~/claw-architect-backup)
BACKUP_REPO_PATH=/Users/tatsheen/claw-architect-backup
# Required only if BACKUP_REPO_PATH is not already a cloned git repo
BACKUP_REPO_GIT_URL=
BACKUP_REPO_BRANCH=main

# ── SaaS Pain Opportunity Pipeline (Reddit + X + Web fallback) ───────────
# Optional: official Reddit API credentials (recommended for stable collection)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=server:claw-architect:1.0 (by /u/tatsheen)
# Optional: X API bearer token for recent search API
X_BEARER_TOKEN=
# Optional tuning
SAAS_PAIN_LIMIT=120
SAAS_PAIN_REDDIT_MAX_REQUESTS=36
SAAS_PAIN_X_MAX_QUERIES=6
SAAS_PAIN_WEB_MAX_REQUESTS=8
SAAS_PAIN_MAX_RUNTIME_MS=420000

# ── Off-grid Smart Home (Meshtastic + Home Assistant + local AI) ─────────
# Meshtastic bridge mode: serial | ble | tcp | simulate
MESHTASTIC_BRIDGE_MODE=serial
# For serial mode (example macOS): /dev/tty.usbmodemXXXX
MESHTASTIC_DEVICE=
# For BLE mode (T-Echo BLE address)
MESHTASTIC_BLE_ADDRESS=
# For TCP mode
MESHTASTIC_TCP_HOST=
MESHTASTIC_TCP_PORT=4403
MESHTASTIC_BRIDGE_POLL_SEC=2
# Data files used by off-grid bridge/dashboard
MESHTASTIC_EVENTS_FILE=/Users/tatsheen/claw-architect/data/offgrid-home/meshtastic-events.jsonl
MESHTASTIC_COMMANDS_FILE=/Users/tatsheen/claw-architect/data/offgrid-home/meshtastic-commands.jsonl
MESHTASTIC_HEARTBEAT_FILE=/Users/tatsheen/claw-architect/data/offgrid-home/meshtastic-heartbeat.json

# Home Assistant local API
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
# Comma-separated entities exposed to off-grid assistant
OFFGRID_LIGHT_ENTITIES=light.living_room,light.bedroom
OFFGRID_SENSOR_ENTITIES=sensor.living_room_temperature,sensor.living_room_humidity
OFFGRID_PRESENCE_ENTITIES=person.tatsheen,person.scott

# Local AI response model (Ollama)
OFFGRID_AI_MODEL=llama3.1:8b

# ── Finance Automation (Plaid + Gmail + Tax Prep) ───────────────────────
PLAID_ENV=production
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ACCESS_TOKEN=
# Optional root for generated tax docs/summaries
TAX_ROOT_DIR=/Users/tatsheen/claw-architect/taxes

# ── OpenClaw Gmail (OAuth2 — no login/password in .env) ─────────────────────
# Use the Gmail you created for OpenClaw. OAuth2 requires Client ID + Secret + Refresh Token.
# 1. Google Cloud Console → your project → APIs & Services → Enable Gmail API
# 2. Credentials → Create OAuth 2.0 Client ID (Desktop or Web). Note Client ID and Secret.
# 3. Run: node agents/google-workspace-agent.js --auth  (open URL, sign in as OpenClaw Gmail, paste code)
# 4. Copy the printed GOOGLE_REFRESH_TOKEN into .env. Optionally set GMAIL_SENDER_EMAIL to that address.
# infra/gmail-client.js and credit send use GOOGLE_OAUTH_*; google-workspace-agent uses GOOGLE_CLIENT_* — set both to same values.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
# Same credentials for Gmail/Drive agent (use same values as above)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── 6AM Task Pull (Todoist / Things) ─────────────────────────────────────
# Todoist API token (required for live close actions)
TODOIST_API_TOKEN=
# Optional: exported Things JSON path (read-only source fallback)
THINGS_EXPORT_JSON=
