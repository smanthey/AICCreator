# NAS deployment env (copy to .env on NAS)

POSTGRES_HOST=192.168.1.164
POSTGRES_PORT=15432
POSTGRES_USER=claw
POSTGRES_PASSWORD=
POSTGRES_DB=claw_architect

# Redis on NAS (container)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Required for worker startup
TELEGRAM_BOT_TOKEN=placeholder

# NAS worker profile: deterministic infra only (no AI)
WORKER_TAGS=infra,deterministic,io_heavy,cpu_heavy
WORKER_ALWAYS_ON=true
NODE_ROLE=nas_worker
WORKER_ENFORCE_ROLE_TAG_POLICY=true

# Optional API keys (can stay empty on NAS deterministic node)
OPENAI_API_KEY=
CLASSIFY_PROVIDER=openai
OPENAI_CLASSIFY_MODEL_KEY=openai_mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Path policy and safety
POLICY_ALLOWED_PATH_PREFIXES=/volume1,/volume2,/tmp,/Users/tatsheen/claw-architect
POLICY_DISABLE_DESTRUCTIVE_FLAGS=true
POLICY_READ_ONLY_MODE=true
POLICY_USE_OPA=true
OPA_URL=http://127.0.0.1:8181/v1/data/claw/policy
OPA_TIMEOUT_MS=3000
POLICY_OPA_FAIL_CLOSED_MUTATING=true
